meta {
  name: Buscar aluno inexistente
  type: http
  seq: 3
}

get {
  url: https://musical-broccoli-r4jw9vg5wgjq25vvg-3000.app.github.dev/alunos/999
  body: none
  auth: inherit
}

tests {
  test("deve retornar status 404 para aluno inexistente", function() {
    expect(res.getStatus()).to.equal(404);
  });
  
  test("deve retornar mensagem de erro", function() {
    expect(res.getBody().erro).to.equal('Aluno não encontrado');
  });
}
