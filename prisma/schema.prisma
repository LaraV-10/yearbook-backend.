// Generator — gera o Prisma Client em JavaScript
generator client {
  provider = "prisma-client-js"
}

// Datasource — conexão com o banco PostgreSQL
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enum — valores fixos para o campo role
enum Role {
  USER
  ADMIN
}

// Model Aluno
model Aluno {
  id            Int        @id @default(autoincrement())
  nome          String
  email         String     @unique
  senhaHash     String
  cidade        String?
  frase         String?
  planosFuturos String?
  fotoUrl       String?
  role          Role       @default(USER)
  criadoEm      DateTime   @default(now())

  mensagens     Mensagem[] // relação 1:N
}

// Model Mensagem
model Mensagem {
  id        Int      @id @default(autoincrement())
  texto     String
  imagemUrl String?
  autorId   Int

  autor     Aluno    @relation(fields: [autorId], references: [id])

  criadoEm  DateTime @default(now())
}